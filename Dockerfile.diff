FROM lcr.loongnix.cn/library/debian:forky

ENV DEBIAN_FRONTEND=noninteractive
ENV JAVA_HOME=/usr/lib/jvm/default-java

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      cargo \
      cmake \
      curl \
      default-jdk \
      erlang \
      file \
      findutils \
      g++ \
      gawk \
      gcc \
      git \
      golang \
      gzip \
      jq \
      make \
      patch \
      perl \
      pkg-config \
      python3 \
      python3-pip \
      python3-venv \
      rustc \
      sed \
      tar \
      unzip \
      wget \
      xz-utils \
      zip && \
    python3 -m pip install --break-system-packages 'conan<2' && \
    rm -rf /var/lib/apt/lists/*

CMD ["/bin/bash"]
